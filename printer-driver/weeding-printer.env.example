# Copy to /etc/weeding-printer.env and fill in your values

# Backend URL (required)
API_BASE=https://your-domain.example.com

# Shared secret (must match the backend's PRINTER_API_KEY)
PRINTER_API_KEY=printer-secret-key

# CUPS printer name — leave empty to auto-detect the first Selphy found
PRINTER_NAME=

# Seconds between /printer/next polls when queue is empty (default: 5)
POLL_INTERVAL=5

# Max seconds to wait for a single CUPS job before declaring failure (default: 300)
JOB_TIMEOUT=300
